NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://locoomo:locoomo@localhost:5434/locoomo
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
# Only needed against a hosted DB (Supabase/Neon) that requires TLS — repo-relative
# path to that provider's CA cert (e.g. certs/supabase-ca.crt). Unset locally, the
# docker-compose Postgres has no TLS.
DATABASE_SSL_CA_PATH=
# Comma-separated browser origins allowed to call this API with credentials
CORS_ORIGIN=http://localhost:5173
