NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://locoomo:locoomo@localhost:5434/locoomo
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
# Only needed against a hosted DB (Supabase/Neon) that requires TLS — repo-relative
# path to that provider's CA cert (e.g. certs/supabase-ca.crt). Unset locally, the
# docker-compose Postgres has no TLS.
DATABASE_SSL_CA_PATH=
# Comma-separated browser origins allowed to call this API with credentials
CORS_ORIGIN=http://localhost:5173
# SMTP only — no provider SDK, so swapping providers is just changing these
# values. Resend's own relay for the pilot: host smtp.resend.com, user
# "resend", password = a Resend API key. Any other SMTP-capable provider
# (SES, Postmark, SendGrid, Mailgun, ...) works the same way.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
